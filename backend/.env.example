# ============================================
# MedInsight Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
#
# LOCAL DEVELOPMENT (PostgreSQL on localhost):
#   DATABASE_URL=postgresql+asyncpg://medinsight:medinsight_secret@localhost:5432/medinsight
#
# NEON (Online PostgreSQL):
#   DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx-yyy.region.aws.neon.tech/dbname?sslmode=require
#
# ============================================

# --- Database ---
# For local dev (Docker or local PostgreSQL):
DATABASE_URL=postgresql+asyncpg://medinsight:medinsight_secret@localhost:5432/medinsight
SYNC_DATABASE_URL=postgresql+sync://medinsight:medinsight_secret@localhost:5432/medinsight

# For Neon (uncomment and replace with your Neon connection string):
# DATABASE_URL=postgresql+asyncpg://neondb_owner:your_password@ep-xxx-yyy.region.aws.neon.tech/medinsight?sslmode=require
# SYNC_DATABASE_URL=postgresql+://neondb_owner:your_password@ep-xxx-yyy.region.aws.neon.tech/medinsight?sslmode=require

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# --- CORS ---
# Comma-separated list of allowed origins (JSON array format)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://medinsight.vercel.app"]
